{
  "name": "onebook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "web",
    "api"
  ],
  "scripts": {
    "test": "npm run test --workspace=@onebook/finance",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=api"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
