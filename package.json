{
  "name": "onebook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "web",
    "api"
  ],
  "scripts": {
    "test": "npm run test --workspace=@onebook/finance",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=api",
    "deploy:api": "wrangler deploy --config api/wrangler.toml",
    "secret": "wrangler secret put --config api/wrangler.toml",
    "secret:list": "wrangler secret list --config api/wrangler.toml",
    "db:remote": "wrangler d1 execute onebook --remote --config api/wrangler.toml --file=api/src/schema.sql",
    "tail": "wrangler tail --config api/wrangler.toml"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
