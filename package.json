{
  "name": "onebook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "web",
    "api"
  ],
  "scripts": {
    "test": "npm run test --workspace=@onebook/finance",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "wrangler dev",
    "deploy:api": "wrangler deploy",
    "secret": "wrangler secret put",
    "secret:list": "wrangler secret list",
    "db:remote": "wrangler d1 execute onebook --remote --file=api/src/schema.sql",
    "tail": "wrangler tail",
    "db:local": "wrangler d1 execute onebook --local --file=api/src/schema.sql"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "wrangler": "^4.112.0"
  }
}
